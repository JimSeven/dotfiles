#!/usr/bin/env bash
set -euo pipefail

# Install global npm packages from npm-globals.txt. Re-runs when the list changes.
# npm-globals hash: {{ include "npm-globals.txt" | sha256sum }}

# Node/npm comes from Laravel Herd's bundled NVM.
export NVM_DIR="$HOME/Library/Application Support/Herd/config/nvm"
# shellcheck disable=SC1091
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"

if ! command -v npm >/dev/null 2>&1; then
  echo "npm not found — launch Laravel Herd once to provision Node, then re-run 'chezmoi apply'." >&2
  exit 0
fi

while IFS= read -r pkg; do
  [[ -z "$pkg" || "$pkg" == \#* ]] && continue
  if npm ls -g --depth=0 "$pkg" >/dev/null 2>&1; then
    echo "==> $pkg already installed"
  else
    echo "==> npm install -g $pkg"
    npm install -g "$pkg"
  fi
done <<'PKGS'
{{ include "npm-globals.txt" }}
PKGS
