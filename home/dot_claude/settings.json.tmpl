{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "opus[1m]",
  "language": "German",
  "tui": "fullscreen",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "voiceEnabled": true,
  "autoMemoryEnabled": false,
  "skipAutoPermissionPrompt": true,
  "statusLine": {
    "type": "command",
    "command": "bash {{ .chezmoi.homeDir }}/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
{{- if .work }}
    "{{ .company.plugin }}@{{ .company.marketplace }}": true,
{{- end }}
    "context-mode@context-mode": true
  },
  "extraKnownMarketplaces": {
{{- if .work }}
    "{{ .company.marketplace }}": {
      "source": {
        "source": "git",
        "url": {{ .company.url | quote }}
      }
    },
{{- end }}
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    }
  }
}
