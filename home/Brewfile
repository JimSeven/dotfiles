# Installed via `brew bundle` (run automatically by chezmoi on change).
# `brew bundle cleanup --file=~/.local/share/chezmoi/home/Brewfile` reports packages
# NOT listed here — removal is always manual, never automatic (grilling decision).

###############################################################################
# Command-line tools                                                          #
###############################################################################

tap "anomalyco/tap"  # third-party tap providing opencode

brew "mas"           # Mac App Store CLI — keep first so mas apps below can install
brew "chezmoi"       # this repo's dotfile manager
brew "git"           # newer than the system Git
brew "git-lfs"       # Git large-file storage
brew "git-delta"     # syntax-highlighted git diff pager
brew "antidote"      # zsh plugin manager — replaces antigen
brew "direnv"        # per-directory environment variables
brew "mysql-client"  # MySQL CLI (keg-only)
brew "starship"      # cross-shell prompt — replaces powerlevel10k
brew "eza"           # modern ls (icons, git-aware, tree)
brew "zoxide"        # smart cd (`z`)
brew "fzf"           # fuzzy finder (Ctrl-R / Ctrl-T)
brew "bat"           # cat with syntax highlighting
brew "fd"            # fast, friendly find
brew "ripgrep"       # fast grep
brew "micro"         # modern terminal editor ($EDITOR)
brew "dockutil"      # manage macOS Dock items (used by the Dock provisioning script)
brew "php-cs-fixer"  # PHP code-style fixer
brew "jpegoptim"     # JPEG optimiser
brew "optipng"       # PNG optimiser
brew "imagemagick"   # image manipulation
brew "ffmpeg"        # audio/video transcoding
brew "gh"            # GitHub CLI (PRs, issues, releases)
brew "shellcheck"    # shell-script linter (matches CI lint step)
brew "uv"            # fast Python package & version manager (Astral) — no global python pin
brew "gogcli"        # Google Workspace CLI
brew "anomalyco/tap/opencode"  # AI coding agent CLI

