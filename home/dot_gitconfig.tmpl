[alias]
	# View abbreviated SHA, description, and history graph of the latest 20 commits
	l = log --pretty=oneline -n 20 --graph --abbrev-commit
	# View the current working tree status using the short format
	s = status -s

[branch]
	# Set up pull to rebase instead of merge
	autoSetupRebase = always

[diff]
	# Detect copies as well as renames
	renames = copies
	tool = vscode

[difftool "vscode"]
	cmd = code --wait --diff $LOCAL $REMOTE

[merge]
	tool = vscode

[mergetool "vscode"]
	cmd = code --wait $MERGED

[init]
	defaultBranch = main

[pull]
	rebase = true

[user]
	name = {{ .name | quote }}
	email = {{ .email | quote }}
	# TODO: replace with your public SSH signing key from 1Password after setup
	# (1Password → the key item → "Copy Public Key"). Format: ssh-ed25519 AAAA...
	signingkey = ssh-ed25519 PLACEHOLDER_REPLACE_AFTER_1PASSWORD_SETUP

# Sign commits and tags with an SSH key held in 1Password (see ADR-0002).
[gpg]
	format = ssh
[gpg "ssh"]
	program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
[commit]
	gpgsign = true
[tag]
	gpgsign = true

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true

[core]
	# Global ignore file (managed as ~/.gitignore by chezmoi)
	excludesfile = {{ .chezmoi.homeDir }}/.gitignore
