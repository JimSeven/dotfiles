[user]
	name = {{ .name | quote }}
	email = {{ .email | quote }}
	# TODO: replace with your public SSH signing key from 1Password after setup
	# (1Password → the key item → "Copy Public Key"). Format: ssh-ed25519 AAAA...
	signingkey = ssh-ed25519 PLACEHOLDER_REPLACE_AFTER_1PASSWORD_SETUP

[init]
	defaultBranch = main

[core]
	autocrlf = input
	excludesfile = {{ .chezmoi.homeDir }}/.gitignore
	pager = delta

# Sign commits and tags with an SSH key held in 1Password (see ADR-0002).
[gpg]
	format = ssh
[gpg "ssh"]
	program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
[commit]
	gpgsign = true
	verbose = true
[tag]
	gpgsign = true
	sort = version:refname

[pull]
	rebase = true
[push]
	default = simple
	autoSetupRemote = true
[rebase]
	autoStash = true
	autoSquash = true
	updateRefs = true
[fetch]
	prune = true
[rerere]
	enabled = true

# Diff & merge experience: delta pager, zdiff3 conflicts, VS Code as the tool.
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	line-numbers = true
[diff]
	algorithm = histogram
	colorMoved = default
	tool = vscode
[difftool "vscode"]
	cmd = code --wait --diff $LOCAL $REMOTE
[merge]
	conflictstyle = zdiff3
	tool = vscode
[mergetool "vscode"]
	cmd = code --wait $MERGED

# Display niceties
[branch]
	sort = -committerdate
[column]
	ui = auto
[help]
	autocorrect = prompt

[alias]
	co = checkout
	ci = commit
	st = status -sb
	br = branch
	lg = log --graph --oneline --decorate --all
	last = log -1 HEAD --stat
	amend = commit --amend --no-edit
	undo = reset --soft HEAD~1
	unstage = reset HEAD --
	aliases = config --get-regexp "^alias\\."

[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
