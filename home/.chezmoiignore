# Files present in the source tree but NOT applied to $HOME.

# The Brewfile is consumed by run_onchange_before_10-install-packages.sh via
# `include`; it must not be copied to ~/Brewfile.
Brewfile

# OS junk — never track anywhere.
.DS_Store

###############################################################################
# AI agent config — version Managed config, never Runtime state (ADR-0006).   #
#                                                                             #
# Each agent dotfolder is managed as a PLAIN (never exact_) directory, so an  #
# apply can never delete unmanaged Runtime state. These rules are the strict  #
# safety floor: default-deny the WHOLE dotfolder, so an accidental            #
# `chezmoi add ~/.claude` (or ~/.codex) can never sweep in credentials,       #
# transcripts, history, caches, sqlite stores/logs or plugin payloads.        #
# Later commits re-include only the specific Managed config paths (settings.  #
# json, CLAUDE.md, statusline for Claude; config.toml + rules/ for Codex) with #
# `!` negations. Skills, MCP wiring, agents/ and commands/ are deliberately    #
# out of scope (ADR-0006) — never re-included, established per machine.        #
###############################################################################

# --- Claude Code (~/.claude) -------------------------------------------------
# Denies all Runtime state, notably:
#   .credentials.json                     credentials/auth
#   settings.local.json                   local settings override
#   projects/ sessions/ session-env/      session transcripts
#   history.jsonl                         prompt history
#   file-history/ shell-snapshots/        file-history, shell snapshots
#   cache/ image-cache/ paste-cache/      caches
#   *-cache.json remote-settings.json     caches / fetched state
#   plugins/                              installed plugin payloads
#   backups/ plans/ tasks/ ide/ chrome/   misc runtime
#   context-mode/ policy-limits.json      plugin runtime / telemetry
#   .last-cleanup *.lock                  runtime markers / locks
.claude/**
# Re-include Managed config (added as each file is brought under chezmoi).
# `.claude/**` also matches the bare dir, so un-ignore the dir itself first —
# otherwise chezmoi never descends and the file negation below is dead.
!.claude
# bridge → canonical Defaults (ADR-0007):
!.claude/CLAUDE.md
# gated settings template + the statusline it references (ADR-0006):
!.claude/settings.json
!.claude/statusline-command.sh

# --- Codex (~/.codex) --------------------------------------------------------
# Denies all Runtime state, notably:
#   auth.json                             credentials/auth
#   sessions/ session_index.jsonl         session transcripts
#   history.jsonl                         prompt history
#   shell_snapshots/                      shell snapshots
#   cache/ models_cache.json              caches
#   *.sqlite *.sqlite-shm *.sqlite-wal    sqlite stores
#   sqlite/ log/                          sqlite stores / logs
#   memories/ vendor_imports/ node_repl/  misc runtime
#   browser/ computer-use/ process_manager/
#   generated_images/ attachments/        generated artefacts
#   plugins/                              installed plugin payloads
#   tmp/ .tmp/ *.bak                       temp / backups
#   installation_id version.json          telemetry / runtime markers
#   .codex-global-state.json .personality_migration
.codex/**
# Re-include Managed config (added as each file is brought under chezmoi).
# `.codex/**` also matches the bare dir, so un-ignore the dir itself first —
# otherwise chezmoi never descends and the file negations below are dead.
!.codex
# curated config.toml — durable user settings only, no token/secret (ADR-0006):
!.codex/config.toml
# tool-specific command rules — managed config (ADR-0006):
!.codex/rules
!.codex/rules/default.rules
# bridge → canonical Defaults (symlink, ADR-0007):
!.codex/AGENTS.md

# --- opencode (~/.config/opencode) -------------------------------------------
# Runtime state here is the installed-plugin payload reproduced declaratively by
# the `plugin` array in opencode.json (ADR-0006), never vendored:
#   node_modules/                         installed plugin payloads
#   bun.lock package-lock.json package.json  lockfiles / manifest
#   .gitignore                            tool-generated
# Default-deny the whole dir so an accidental `chezmoi add` cannot sweep them in.
.config/opencode/**
!.config/opencode
# config pointed at the Defaults via `instructions` (ADR-0007):
!.config/opencode/opencode.json

###############################################################################
# VS Code user settings — seed once, then hands off (ADR-0011).               #
#                                                                             #
# settings.json is real JSONC (comments + trailing commas) that VS Code and   #
# its extensions actively rewrite at runtime, and no CLI JSON tool can merge   #
# it without destroying the comments. So chezmoi seeds the curated baseline    #
# on a fresh machine (file absent → not ignored → applied), then ignores it    #
# once present so runtime rewrites never prompt. Baseline changes are rolled   #
# out deliberately with `chezmoi apply --force '~/Library/.../settings.json'`. #
###############################################################################
{{ if stat (joinPath .chezmoi.homeDir "Library/Application Support/Code/User/settings.json") }}
Library/Application Support/Code/User/settings.json
{{ end -}}
